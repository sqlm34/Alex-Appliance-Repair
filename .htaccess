RewriteEngine On

# Canonical host: force every public request to https://alex-repair.com.
RewriteCond %{HTTP_HOST} ^www\.alex-repair\.com$ [NC]
RewriteRule ^ https://alex-repair.com%{REQUEST_URI} [R=301,L,NE]

RewriteCond %{HTTP_HOST} ^alex-repair\.com$ [NC]
RewriteCond %{HTTPS} !=on
RewriteRule ^ https://alex-repair.com%{REQUEST_URI} [R=301,L,NE]

<IfModule mod_expires.c>
ExpiresActive On
ExpiresByType text/css "access plus 1 year"
ExpiresByType application/javascript "access plus 1 year"
ExpiresByType text/javascript "access plus 1 year"
ExpiresByType image/webp "access plus 1 year"
ExpiresByType image/png "access plus 1 year"
ExpiresByType image/jpeg "access plus 1 year"
ExpiresByType image/svg+xml "access plus 1 year"
ExpiresByType font/woff2 "access plus 1 year"
</IfModule>

<IfModule mod_headers.c>
<FilesMatch "\.(css|js|webp|png|jpe?g|svg|woff2)$">
Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>
</IfModule>

RewriteCond %{HTTP_HOST} ^(www\.)?alexrepair\.us$ [NC]
RewriteRule ^(.*)$ https://alex-repair.com/$1 [R=301,L]

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ https://alex-repair.com/ [R=301,L]

RedirectMatch 410 ^/product-category/
RedirectMatch 410 ^/product/
RedirectMatch 410 ^/shop/

Redirect 301 /blog-details.html https://alex-repair.com/blog.html
