RewriteEngine On

RewriteCond %{HTTP_HOST} ^www\.alex-repair\.com$ [NC]
RewriteRule ^(.*)$ https://alex-repair.com/$1 [R=301,L]

RedirectMatch 410 ^/product-category/
RedirectMatch 410 ^/product/
RedirectMatch 410 ^/shop/

Redirect 301 /refrigirator-repair.html https://alex-repair.com/refrigerator-repair.html
Redirect 301 /carmel/refrigirator-repair-services.html https://alex-repair.com/carmel/refrigerator-repair-services.html
Redirect 301 /fishers/refrigirator-repair-services.html https://alex-repair.com/fishers/refrigerator-repair-services.html
Redirect 301 /noblesville/refrigirator-repair-services.html https://alex-repair.com/noblesville/refrigerator-repair-services.html
Redirect 301 /mccordsville/refrigirator-repair-services.html https://alex-repair.com/mccordsville/refrigerator-repair-services.html
Redirect 301 /westfield/refrigirator-repair-services.html https://alex-repair.com/westfield/refrigerator-repair-services.html
Redirect 301 /zionsville/refrigirator-repair-services.html https://alex-repair.com/zionsville/refrigerator-repair-services.html
